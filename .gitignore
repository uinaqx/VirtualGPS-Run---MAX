# Gradle files
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Local configuration file (sdk path, etc)
local.properties
secrets.properties

# Android Studio
*.iml
.idea/
.navigation/
captures/
.output/

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# Claude Code
.claude/

# OS-specific files
.DS_Store
Thumbs.db

# Log files
*.log

# APK files (should be released via release/ folder, not in root)
*.apk
*.ap_
*.aab
!release/*.apk

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# Kotlin
.kotlin/
